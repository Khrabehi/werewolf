<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.werewolf.GameController"
           prefWidth="900" prefHeight="600">

    <!-- Dark night-sky background -->
    <Rectangle width="900" height="600" fill="#0d0d2b"/>

    <VBox alignment="CENTER" spacing="30">

        <Label fx:id="phaseLabel"
               text="Night falls upon the village…"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e0c97f;"/>

        <Button fx:id="startButton"
                text="Start Game"
                onAction="#handleStartGame"
                style="-fx-background-color: #8b0000;
                       -fx-text-fill: white;
                       -fx-font-size: 16px;
                       -fx-padding: 10 30 10 30;
                       -fx-border-radius: 6;
                       -fx-background-radius: 6;"/>

    </VBox>

</StackPane>
